<+>@import url('https://fonts.googleapis.com/css2?family=Poller+One&display=swap');\r\n\r\n* {\r\n    margin: 0;\r\n    box-sizing: border-box;\r\n}\r\n\r\nbody {\r\n    font-family: 'Poller One', cursive;\r\n    background-image: url('../images/sky.jpg');\r\n    color: #eedb00;\r\n    background-attachment: fixed;\r\n}\r\n\r\nheader, footer {\r\n    background-color: rgba(60, 69, 67, 0.6);\r\n}\r\n\r\nheader {\r\n    border-radius: 16px 16px 0 0;\r\n}\r\n\r\nh1 {\r\n    text-align: center;\r\n    font-size: 3em;\r\n    padding-top: 0.7em;\r\n    padding-bottom: 0.4em;\r\n}\r\n\r\nnav {\r\n    position: fixed;\r\n    top: 5px;\r\n    left: 40px;\r\n}\r\n\r\nnav > ul {\r\n    list-style: none;\r\n    padding: 0;\r\n}\r\n\r\n.button {\r\n    display: inline-block;\r\n    border: 2px solid black;\r\n    background-color: rgba(204, 3, 35, 0.5);\r\n    cursor: pointer;\r\n    font-size: 0.8em;\r\n    padding: 0.3em 0.5em;\r\n    border-radius: 5px;\r\n}\r\n\r\n.left {\r\n    float: left;\r\n    margin: 0.3rem 1.2rem 0 0;\r\n    width: 25%;\r\n}\r\n\r\n.left > img {\r\n    width: 100%;\r\n    box-shadow: 11px 10px 7px -1px rgba(255, 255, 255, 0.41);\r\n}\r\n\r\n.right {\r\n    width: 50%;\r\n    float: right;\r\n    border: #eedb00 1px solid;\r\n    border-radius: 0 0 16px 16px;\r\n    padding: 0 0.1rem;\r\n    margin: 5px 5px 0 10px;\r\n}\r\n\r\n.right > h2 {\r\n    margin: 0.5rem 0;\r\n    font-size: 1.2rem;\r\n    text-align: center;\r\n}\r\n\r\ntable {\r\n    border-collapse: collapse;\r\n    width: 100%;\r\n    table-layout: fixed;\r\n}\r\n\r\ntd {\r\n    padding: 0;\r\n}\r\n\r\nimg[alt=\"Friend\"] {\r\n    border-radius: 0.8rem;\r\n    padding: 0.1rem;\r\n    width: 100%;\r\n    display: block;\r\n}\r\n\r\n.far-galaxy {\r\n    text-align: justify;\r\n    font-size: 1.7rem;\r\n    line-height: 1.6;\r\n    letter-spacing: 0.1rem;\r\n}\r\n\r\nfooter {\r\n    border-radius: 0 0 16px 16px;\r\n    height: 5em;\r\n    clear: both;\r\n    padding: 5px 40px;\r\n    text-align: right;\r\n    margin-top: 10px\r\n}\r\n\r\n\r\n\r\n\r\n
